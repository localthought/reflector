{
  "name": "reflector",
  "version": "0.1.0",
  "description": "A local-first web app that syncs your systems of record — starting with the Google Calendar API and your own remoteStorage account — keeping a local JSON copy you can sync and, as a side feature, download as a ZIP. Uses localthought/syncables as the sync engine and the localthought/overlays Calendar overlay.",
  "type": "module",
  "engines": {
    "node": ">= 22.11 < 23"
  },
  "dependencies": {
    "express": "~4.21",
    "js-yaml": "~4.1",
    "jszip": "~3.10",
    "syncables": "0.16.0",
    "tslib": "~2.8"
  },
  "devDependencies": {
    "@eslint/js": "~9.17",
    "@types/eslint__js": "~8.42",
    "@types/express": "~4.17",
    "@types/js-yaml": "~4.0",
    "@types/node": "~20",
    "@typescript-eslint/parser": "~8.19",
    "@vitest/coverage-v8": "~2.1",
    "@vitest/eslint-plugin": "~1.1",
    "eslint": "~9.17",
    "eslint-config-prettier": "~9.1",
    "globals": "~15.14",
    "prettier": "~3.4",
    "rimraf": "~6.0",
    "ts-api-utils": "~2.0",
    "typescript": "~5.7",
    "typescript-eslint": "~8.19",
    "vitest": "~2.1"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "clean": "rimraf coverage build tmp",
    "build": "tsc -p tsconfig.json",
    "build:release": "npm run clean && tsc -p tsconfig.release.json",
    "start": "NODE_OPTIONS=--enable-source-maps node build/src/main.js",
    "dev": "npm run build && npm run start",
    "lint": "eslint .",
    "test": "vitest run unit --config __tests__/vitest.config.ts",
    "test:coverage": "vitest run unit --config __tests__/vitest.config.ts --coverage.enabled --coverage.all",
    "prettier": "prettier \"{src,__{tests}__}/**/*.{ts,mts}\" --config .prettierrc --write",
    "prettier:check": "prettier \"{src,__{tests}__}/**/*.{ts,mts}\" --config .prettierrc --check"
  },
  "author": "Michiel de Jong <michiel@unhosted.org>",
  "license": "Apache-2.0",
  "volta": {
    "node": "22.12.0"
  }
}
